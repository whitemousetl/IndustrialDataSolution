<hc:Window  x:Class="IndustrialDataProcessor.WpfClient.Views.MainWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:hc="https://handyorg.github.io/handycontrol"
            xmlns:local="clr-namespace:IndustrialDataProcessor.WpfClient.Views" 
            mc:Ignorable="d"
            Title="工业数据采集与控制系统" Height="800" Width="1280">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 顶部工具栏 -->
            <RowDefinition Height="*"/>     <!-- 侧边菜单 + 内容区 -->
            <RowDefinition Height="Auto"/>  <!-- 底部状态栏 -->
        </Grid.RowDefinitions>

       <!--顶部工具栏(精简版，只保留常用操作按钮)-->
        <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0 0 0 1" Padding="16 8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                
                <!--左侧：系统标题-->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Width="24" Height="24"
                          Data="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10 10,-4.48 10,-10S17.52,2 12,2z M12,20c-4.41,0 -8,-3.59 -8,-8s3.59,-8 8,-8 8,3.59 8,8 -3.59,8 -8,8z M12.5,7H11v6l5.25,3.15 0.75,-1.23 -4.5,-2.67z"
                          Fill="{DynamicResource PrimaryBrush}"
                          Stretch="Uniform"/>
                    <TextBlock Text="工业数据采集与监控系统"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <!--中间：快捷操作按钮-->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button Content="保存配置" Command="{Binding SaveCurrentConfigCommand}" Style="{StaticResource ButtonPrimary}" Margin="0 0 8 0"/>
                    <Button Content="连接 OPC UA" Command="{Binding ConnectOpcUaCommand}" Style="{StaticResource ButtonDefault}" Margin="0 0 8 0"/>
                    <Button Content="连接后端 API" Command="{Binding ConnectApiCommand}" Style="{StaticResource ButtonDefault}" Margin="0 0 8 0"/>
                </StackPanel>
                
                <!--右侧：用户信息 + 设置-->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ButtonIcon}"
                            Command="{Binding OpenSettingsCommand}"
                            Margin="0,0,8,0">
                        <Path Width="16" Height="16"
                              Data="M19.14,12.94c0.04,-0.3 0.06,-0.61 0.06,-0.94c0,-0.32 -0.02,-0.64 -0.07,-0.94l2.03,-1.58c0.18,-0.14 0.23,-0.41 0.12,-0.61l-1.92,-3.32c-0.12,-0.22 -0.37,-0.29 -0.59,-0.22l-2.39,0.96c-0.5,-0.38 -1.03,-0.7 -1.62,-0.94L14.4,3.81c-0.04,-0.24 -0.24,-0.41 -0.48,-0.41h-3.84c-0.24,0 -0.43,0.17 -0.47,0.41L9.25,6.35C8.66,6.59 8.12,6.92 7.63,7.31L5.24,6.35c-0.22,-0.08 -0.47,0 -0.59,0.22L2.74,9.88c-0.12,0.21 -0.08,0.47 0.12,0.61l2.03,1.58C4.84,12.36 4.8,12.69 4.8,13s0.02,0.64 0.07,0.94l-2.03,1.58c-0.18,0.14 -0.23,0.41 -0.12,0.61l1.92,3.32c0.12,0.22 0.37,0.29 0.59,0.22l2.39,-0.96c0.5,0.38 1.03,0.7 1.62,0.94l0.36,2.54c0.05,0.24 0.24,0.41 0.48,0.41h3.84c0.24,0 0.44,-0.17 0.47,-0.41l0.36,-2.54c0.59,-0.24 1.13,-0.56 1.62,-0.94l2.39,0.96c0.22,0.08 0.47,0 0.59,-0.22l1.92,-3.32c0.12,-0.22 0.07,-0.47 -0.12,-0.61L19.14,12.94z M12,15.6c-1.43,0 -2.6,-1.16 -2.6,-2.6c0,-1.43 1.16,-2.6 2.6,-2.6s2.6,1.16 2.6,2.6C14.6,14.44 13.43,15.6 12,15.6z"
                              Fill="{DynamicResource PrimaryTextBrush}"
                              Stretch="Uniform"/>
                    </Button>
                    <hc:SplitButton Style="{StaticResource SplitButtonPrimary}" Content="{Binding CurrentUserName}" Command="{Binding SelectCommand}" CommandParameter="Command0" HorizontalAlignment="Stretch">
                        <hc:SplitButton.DropDownContent>
                            <StackPanel>
                                <MenuItem Header="个人设置" Command="{Binding SelectCommand}" CommandParameter="Command1"/>
                                <MenuItem Header="退出登录" Command="{Binding SelectCommand}" CommandParameter="Command2"/>
                            </StackPanel>
                        </hc:SplitButton.DropDownContent>
                    </hc:SplitButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 中间区域：侧边菜单 + 内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!--左侧：HandyControl SideMenu-->
            <hc:SideMenu Grid.Column="0" Width="220" BorderThickness="0 0 1 0" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource RegionBrush}">
                <!--绑定 SelectionChanged 事件到命令-->
                <hc:Interaction.Triggers>
                    <hc:EventTrigger EventName="SelectionChanged">
                        <hc:EventToCommand Command="{Binding NavigationChangedCommand}" PassEventArgsToCommand="True"/>
                    </hc:EventTrigger>
                </hc:Interaction.Triggers>

                <!-- 配置管理 -->
                <hc:SideMenuItem Header="配置管理">
                    <hc:SideMenuItem.Icon>
                        <Path Width="20" Height="20"
                              Data="M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14c0,3.31 2.69,6 6,6h13c2.76,0 5,-2.24 5,-5 0,-2.64 -2.05,-4.78 -4.65,-4.96zM14,13v4h-4v-4H7l5,-5 5,5H14z"
                              Fill="{DynamicResource PrimaryBrush}"
                              Stretch="Uniform"/>
                    </hc:SideMenuItem.Icon>
                    <hc:SideMenuItem Header="工作站配置"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="WorkstationConfig">
                        <hc:SideMenuItem.Icon>
                            <Path Width="16" Height="16"
                                  Data="M4,6H2v14c0,1.1 0.9,2 2,2h14v-2H4V6zM20,2H8c-1.1,0 -2,0.9 -2,2v12c0,1.1 0.9,2 2,2h12c1.1,0 2,-0.9 2,-2V4C22,2.9 21.1,2 20,2zM20,12l-2.5,-1.5L15,12V4h5V12z"
                                  Fill="{DynamicResource PrimaryTextBrush}"
                                  Stretch="Uniform"/>
                        </hc:SideMenuItem.Icon>
                    </hc:SideMenuItem>
                    <hc:SideMenuItem Header="协议配置"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="ProtocolConfig">
                        <hc:SideMenuItem.Icon>
                            <Path Width="16" Height="16"
                                  Data="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10 10,-4.48 10,-10S17.52,2 12,2zM4,12c0,-4.42 3.58,-8 8,-8 1.85,0 3.55,0.63 4.9,1.69L5.69,16.9C4.63,15.55 4,13.85 4,12zM12,20c-1.85,0 -3.55,-0.63 -4.9,-1.69L18.31,7.1C19.37,8.45 20,10.15 20,12c0,4.42 -3.58,8 -8,8z"
                                  Fill="{DynamicResource PrimaryTextBrush}"
                                  Stretch="Uniform"/>
                        </hc:SideMenuItem.Icon>
                    </hc:SideMenuItem>
                </hc:SideMenuItem>

                <!-- 任务控制 -->
                <hc:SideMenuItem Header="任务控制">
                    <hc:SideMenuItem.Icon>
                        <Path Width="20" Height="20"
                              Data="M8,5v14l11,-7L8,5z"
                              Fill="{DynamicResource PrimaryBrush}"
                              Stretch="Uniform"/>
                    </hc:SideMenuItem.Icon>
                    <hc:SideMenuItem Header="任务下发"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="TaskControl">
                        <hc:SideMenuItem.Icon>
                            <Path Width="16" Height="16"
                                  Data="M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14c0,3.31 2.69,6 6,6h13c2.76,0 5,-2.24 5,-5C24,12.36 21.95,10.22 19.35,10.04zM19,18H6c-2.21,0 -4,-1.79 -4,-4c0,-2.05 1.53,-3.76 3.56,-3.97l1.07,-0.11l0.5,-0.95C8.08,7.14 9.94,6 12,6c2.62,0 4.88,1.86 5.39,4.43l0.3,1.5l1.53,0.11C20.91,12.16 22,13.51 22,15C22,16.65 20.65,18 19,18zM8,13h2.55v3h2.9v-3H16l-4,-4L8,13z"
                                  Fill="{DynamicResource PrimaryTextBrush}"
                                  Stretch="Uniform"/>
                        </hc:SideMenuItem.Icon>
                    </hc:SideMenuItem>
                    <hc:SideMenuItem Header="运行状态"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="TaskStatus">
                        <hc:SideMenuItem.Icon>
                            <Path Width="16" Height="16"
                                  Data="M16,6l2.29,2.29 -4.88,4.88 -4,-4L2,16.59 3.41,18l6,-6 4,4 6.3,-6.29L22,12V6H16z"
                                  Fill="{DynamicResource PrimaryTextBrush}"
                                  Stretch="Uniform"/>
                        </hc:SideMenuItem.Icon>
                    </hc:SideMenuItem>
                </hc:SideMenuItem>

                <!-- 实时监控 -->
                <hc:SideMenuItem Header="实时监控"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="RealTimeMonitor">
                    <hc:SideMenuItem.Icon>
                        <Path Width="20" Height="20"
                              Data="M3.5,18.49l6,-6.01 4,4L22,6.92l-1.41,-1.41 -7.09,7.97 -4,-4L2,16.99l1.5,1.5z"
                              Fill="{DynamicResource PrimaryBrush}"
                              Stretch="Uniform"/>
                    </hc:SideMenuItem.Icon>
                </hc:SideMenuItem>

                <!-- 报警管理 -->
                <hc:SideMenuItem Header="报警管理">
                    <hc:SideMenuItem.Icon>
                        <Path Width="20" Height="20"
                              Data="M1,21h22L12,2L1,21zM13,18h-2v-2h2V18zM13,14h-2v-4h2V14z"
                              Fill="{DynamicResource WarningBrush}"
                              Stretch="Uniform"/>
                    </hc:SideMenuItem.Icon>
                    <hc:SideMenuItem Header="实时报警"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="AlarmRealtime">
                        <hc:SideMenuItem.Icon>
                            <Path Width="16" Height="16"
                                  Data="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10 10,-4.48 10,-10S17.52,2 12,2zM13,17h-2v-6h2V17zM13,9h-2V7h2V9z"
                                  Fill="{DynamicResource PrimaryTextBrush}"
                                  Stretch="Uniform"/>
                        </hc:SideMenuItem.Icon>
                    </hc:SideMenuItem>
                    <hc:SideMenuItem Header="历史报警"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="AlarmHistory">
                        <hc:SideMenuItem.Icon>
                            <Path Width="16" Height="16"
                                  Data="M13,3c-4.97,0 -9,4.03 -9,9H1l3.89,3.89 0.07,0.14L9,12H6c0,-3.87 3.13,-7 7,-7s7,3.13 7,7 -3.13,7 -7,7c-1.93,0 -3.68,-0.79 -4.94,-2.06l-1.42,1.42C8.27,19.99 10.51,21 13,21c4.97,0 9,-4.03 9,-9S17.97,3 13,3zM12,8v5l4.28,2.54 0.72,-1.21 -3.5,-2.08V8H12z"
                                  Fill="{DynamicResource PrimaryTextBrush}"
                                  Stretch="Uniform"/>
                        </hc:SideMenuItem.Icon>
                    </hc:SideMenuItem>
                </hc:SideMenuItem>

                <!-- 日志管理 -->
                <hc:SideMenuItem Header="日志管理"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="Log">
                    <hc:SideMenuItem.Icon>
                        <Path Width="20" Height="20"
                              Data="M14,2H6c-1.1,0 -1.99,0.9 -1.99,2L4,20c0,1.1 0.89,2 1.99,2H18c1.1,0 2,-0.9 2,-2V8L14,2zM16,18H8v-2h8V18zM16,14H8v-2h8V14zM13,9V3.5L18.5,9H13z"
                              Fill="{DynamicResource PrimaryBrush}"
                              Stretch="Uniform"/>
                    </hc:SideMenuItem.Icon>
                </hc:SideMenuItem>

                <!-- 系统设置 -->
                <hc:SideMenuItem Header="系统设置"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="Settings">
                    <hc:SideMenuItem.Icon>
                        <Path Width="20" Height="20"
                              Data="M19.14,12.94c0.04,-0.3 0.06,-0.61 0.06,-0.94c0,-0.32 -0.02,-0.64 -0.07,-0.94l2.03,-1.58c0.18,-0.14 0.23,-0.41 0.12,-0.61l-1.92,-3.32c-0.12,-0.22 -0.37,-0.29 -0.59,-0.22l-2.39,0.96c-0.5,-0.38 -1.03,-0.7 -1.62,-0.94L14.4,3.81c-0.04,-0.24 -0.24,-0.41 -0.48,-0.41h-3.84c-0.24,0 -0.43,0.17 -0.47,0.41L9.25,6.35C8.66,6.59 8.12,6.92 7.63,7.31L5.24,6.35c-0.22,-0.08 -0.47,0 -0.59,0.22L2.74,9.88c-0.12,0.21 -0.08,0.47 0.12,0.61l2.03,1.58C4.84,12.36 4.8,12.69 4.8,13s0.02,0.64 0.07,0.94l-2.03,1.58c-0.18,0.14 -0.23,0.41 -0.12,0.61l1.92,3.32c0.12,0.22 0.37,0.29 0.59,0.22l2.39,-0.96c0.5,0.38 1.03,0.7 1.62,0.94l0.36,2.54c0.05,0.24 0.24,0.41 0.48,0.41h3.84c0.24,0 0.44,-0.17 0.47,-0.41l0.36,-2.54c0.59,-0.24 1.13,-0.56 1.62,-0.94l2.39,0.96c0.22,0.08 0.47,0 0.59,-0.22l1.92,-3.32c0.12,-0.22 0.07,-0.47 -0.12,-0.61L19.14,12.94zM12,15.6c-1.43,0 -2.6,-1.16 -2.6,-2.6c0,-1.43 1.16,-2.6 2.6,-2.6s2.6,1.16 2.6,2.6C14.6,14.44 13.43,15.6 12,15.6z"
                              Fill="{DynamicResource PrimaryBrush}"
                              Stretch="Uniform"/>
                    </hc:SideMenuItem.Icon>
                </hc:SideMenuItem>
            </hc:SideMenu>

            <!-- 右侧：内容展示区 -->
            <hc:TransitioningContentControl Grid.Column="1"
                                            Content="{Binding CurrentViewModel}"
                                            Margin="16">
                <!-- 页面切换动画效果 -->
                <!--<hc:TransitioningContentControl.Transition>
                    <hc:TransitionEffect Kind="Fade"/>
                </hc:TransitioningContentControl.Transition>-->
            </hc:TransitioningContentControl>
        </Grid>

        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="2"
                   Background="{DynamicResource RegionBrush}"
                   BorderBrush="{DynamicResource BorderBrush}"
                   BorderThickness="0,1,0,0"
                   Padding="16,4">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <!-- OPC UA 连接状态 -->
            <StatusBarItem Grid.Column="0" Margin="0,0,24,0">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOpcUaConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="OPC UA"/>
                    <TextBlock Text="{Binding OpcUaStatusText, Mode=OneWay}" Margin="4,0,0,0"/>
                </StackPanel>
            </StatusBarItem>

            <!-- API 连接状态 -->
            <StatusBarItem Grid.Column="1" Margin="0,0,24,0">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsApiConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="API"/>
                    <TextBlock Text="{Binding ApiStatusText, Mode=OneWay}" Margin="4,0,0,0"/>
                </StackPanel>
            </StatusBarItem>

            <!-- 当前视图 -->
            <StatusBarItem Grid.Column="2" Margin="0,0,24,0">
                <TextBlock>
                    <Run Text="当前视图："/>
                    <Run Text="{Binding CurrentViewName, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>
            </StatusBarItem>

            <!-- 当前时间 -->
            <StatusBarItem Grid.Column="4">
                <TextBlock Text="{Binding CurrentTime, Mode=OneWay}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</hc:Window>
