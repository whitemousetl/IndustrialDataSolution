<UserControl x:Class="IndustrialDataProcessor.WpfClient.Views.WorkstationConfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:IndustrialDataProcessor.WpfClient.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <TextBlock Grid.Row="0"
                   Text="{Binding PageTitle}"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <!-- 工作站基础信息卡片 -->
        <hc:Card Grid.Row="1" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="基础信息" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 工作站ID -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="工作站ID" Margin="0,0,0,4"/>
                        <hc:TextBox Text="{Binding WorkstationId, UpdateSourceTrigger=PropertyChanged}"
                                    hc:InfoElement.Placeholder="请输入工作站ID"
                                    hc:InfoElement.ShowClearButton="True"/>
                    </StackPanel>

                    <!-- 工作站名称 -->
                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="工作站名称" Margin="0,0,0,4"/>
                        <hc:TextBox Text="{Binding WorkstationName, UpdateSourceTrigger=PropertyChanged}"
                                    hc:InfoElement.Placeholder="请输入工作站名称"
                                    hc:InfoElement.ShowClearButton="True"/>
                    </StackPanel>

                    <!-- IP地址 -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="IP地址" Margin="0,0,0,4"/>
                        <hc:TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                                    hc:InfoElement.Placeholder="例如: 192.168.1.100"
                                    hc:InfoElement.ShowClearButton="True"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </hc:Card>

        <!-- 协议配置区域 -->
        <hc:Card Grid.Row="2" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 协议列表标题和操作按钮 -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="协议配置" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="添加协议"
                                Command="{Binding AddProtocolCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                Margin="0,0,8,0"/>
                    </StackPanel>
                </Grid>

                <!-- 协议列表 -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Protocols}"
                          SelectedItem="{Binding SelectedProtocol}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="协议ID" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="接口类型" Binding="{Binding InterfaceType}" Width="100"/>
                        <DataGridTextColumn Header="协议类型" Binding="{Binding ProtocolType}" Width="120"/>
                        <DataGridTextColumn Header="IP地址" Binding="{Binding IpAddress}" Width="120"/>
                        <DataGridTextColumn Header="端口" Binding="{Binding ProtocolPort}" Width="80"/>
                        <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*"/>

                        <DataGridTemplateColumn Header="操作" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="编辑"
                                                Command="{Binding DataContext.EditProtocolCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ButtonDefault}"
                                                Margin="0,0,4,0"
                                                Padding="8,2"/>
                                        <Button Content="删除"
                                                Command="{Binding DataContext.RemoveProtocolCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ButtonDanger}"
                                                Padding="8,2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </hc:Card>

        <!-- 底部操作栏 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="加载配置"
                    Command="{Binding LoadConfigCommand}"
                    Style="{StaticResource ButtonDefault}"
                    Margin="0,0,8,0"
                    MinWidth="100"/>
            <Button Content="保存配置"
                    Command="{Binding SaveConfigCommand}"
                    Style="{StaticResource ButtonPrimary}"
                    MinWidth="100"/>
        </StackPanel>

        <!-- 加载遮罩 -->
        <hc:LoadingCircle Grid.RowSpan="4"
                          Visibility="{Binding IsLoading, Converter={StaticResource Boolean2VisibilityConverter}}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
    </Grid>
</UserControl>